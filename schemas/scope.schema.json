{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pryv/compliance-matrix/schemas/scope.schema.json",
  "title": "Scope",
  "description": "A regulation, standard, or hosting certification mapped by the matrix.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "type", "jurisdiction", "version", "version_date", "requirements"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable scope identifier in kebab-case (e.g., 'gdpr', 'iso-27001', 'hipaa-security').",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "short": {
      "type": "string",
      "description": "Display short name (e.g., 'GDPR', 'HIPAA-Security')."
    },
    "type": {
      "enum": ["regulation", "standard", "hosting-cert", "discipline"],
      "description": "regulation = law; standard = ISO-style cert spec; hosting-cert = infrastructure cert (HDS); discipline = organizational framework (data governance, etc.) not tied to a single regulator."
    },
    "jurisdiction": {
      "type": "string",
      "description": "Free text (e.g., 'EU + EEA', 'US', 'Switzerland', 'France', 'International')."
    },
    "version": {
      "type": "string",
      "description": "Version identifier of the regulation/standard (e.g., 'Regulation (EU) 2016/679 (consolidated)')."
    },
    "version_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date of the version pinned."
    },
    "canonical_url": {
      "type": "string",
      "format": "uri"
    },
    "matrix_language": {
      "type": "string",
      "default": "EN"
    },
    "curated": {
      "type": "boolean",
      "default": false,
      "description": "When true, only requirements with non-out-of-scope coverage are authored; excluded clauses listed in excluded_items."
    },
    "layered_on": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Scope id this scope layers on top of (e.g., 'gdpr' for DiGA)."
      },
      "uniqueItems": true,
      "default": []
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "./requirement.schema.json"
      },
      "minItems": 0
    },
    "excluded_items": {
      "type": "array",
      "description": "For curated scopes: clauses deliberately not authored, with rationale (preserves audit-traceability).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "reason"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._()\\-]+$"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "change"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "change": {
            "type": "string"
          },
          "by": {
            "type": "string"
          }
        }
      },
      "default": []
    }
  },
  "allOf": [
    {
      "description": "Curated scopes must populate excluded_items.",
      "if": {
        "properties": { "curated": { "const": true } },
        "required": ["curated"]
      },
      "then": {
        "properties": {
          "excluded_items": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ]
}
